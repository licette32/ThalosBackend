# ============================================================
# Thalos Backend — Environment variables
# ------------------------------------------------------------
# Copy this file to `.env.local` and fill in the real values.
# These are EXAMPLE values (placeholders): do NOT commit real secrets.
# `.env` and `.env.local` are gitignored and must never be committed.
# ============================================================

# ---- Core (required) ----------------------------------------

# Secret used to sign/verify the app JWT (HS256).
# MUST be identical to the ThalosFrontend JWT_SECRET; if they differ,
# tokens issued by the frontend are rejected with 401.
JWT_SECRET="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30"

# Supabase project URL (the same project the frontend uses).
SUPABASE_URL="https://cpkjclwvgnxgadiaoaei.supabase.co"

# Supabase service role key (server-side only, full DB access).
# KEEP SECRET: never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwa2pjbHd2Z254Z2FkaWFvYWVpIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MzI2NDY4MCwiZXhwIjoyMDg4ODQwNjgwfQ.Y_6TDqBdsJNIQisb5RvEA2ntkv8OdFEImrNX5wy_cXM"

# Shared secret for the internal Next.js -> Nest relay
# (header x-thalos-internal-secret). MUST match the ThalosFrontend
# THALOS_INTERNAL_SECRET.
THALOS_INTERNAL_SECRET="xeyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30yz"

# ---- Trustless Work (required for escrow operations) --------

# Base URL of the Trustless Work API.
TRUSTLESSWORK_API_URL="https://dev.api.trustlesswork.com"

# Trustless Work API key, injected server-side by the relay.
# NEVER expose it to the browser.
TRUSTLESSWORK_API_KEY="replace-with-the-trustlesswork-api-key"

# ---- Email notifications (required to send emails) ----------

# Resend API key. If unset, email notifications are disabled
# (logged, non-fatal).
RESEND_API_KEY="replace-with-the-resend-api-key"

# ---- Server (optional) --------------------------------------

# HTTP port. Defaults to 3001 when unset.
PORT="3001"

# Comma-separated list of allowed CORS origins.
# Defaults to allowing all origins when unset.
THALOS_CORS_ORIGIN="http://localhost:3000"
